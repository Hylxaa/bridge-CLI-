# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (so only YOU can use the bot).
# Get it from @userinfobot on Telegram.
ALLOWED_CHAT_ID=

# Default folder Claude works in when a session starts.
# Leave empty to use your home directory. Change anytime in chat with /cd <path>
DEFAULT_WORKDIR=

# Default model + reasoning effort (optional).
# Models: opus | sonnet | fable    Effort: low | medium | high | xhigh | max
DEFAULT_MODEL=opus
DEFAULT_EFFORT=high
